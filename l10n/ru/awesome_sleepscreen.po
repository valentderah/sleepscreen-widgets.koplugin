msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"

msgid "Awesome sleepscreen"
msgstr "Awesome Sleepscreen"

msgid "Awesome sleepscreen (sleep banner)"
msgstr "Awesome Sleepscreen (баннер сна)"

msgid "3×3 sleep banner grid with Frame-style widget cards: clocks, templates, highlights, date/battery/book/calendar, and reading time."
msgstr "Сетка баннера сна 3×3 с карточками виджетов в стиле Frame: часы, шаблоны, подсветки, дата/батарея/книга/календарь и время чтения."

msgid "When ON, replaces the sleep-screen banner with the 3×3 grid layout when KOReader uses Banner message mode."
msgstr "Если включено, баннер экрана сна заменяется сеткой 3×3 при режиме сообщения «Banner» в KOReader."

msgid "Sleep screen layout"
msgstr "Макет экрана сна"

msgid "Grid zones and banner appearance."
msgstr "Зоны сетки и оформление баннера."

msgid "Cancel"
msgstr "Отмена"

msgid "Save"
msgstr "Сохранить"

msgid "Custom sleepscreen banner"
msgstr "Пользовательский баннер экрана сна"

msgid "Kobo-style sleep screen banner with presets and custom templates."
msgstr "Баннер экрана сна в стиле Kobo с пресетами и своими шаблонами."

msgid "Enable Kobo-style banner"
msgstr "Включить баннер в стиле Kobo"

msgid "When ON, replaces the sleep-screen banner text with the framed layout (cover/random/document-cover wallpapers + Banner message mode)."
msgstr "Если включено, текст баннера на экране сна заменяется оформленной рамкой (обложка/случайное изображение/обложка документа и режим сообщения «Banner»)."

msgid "Preset: Name, progress & quote"
msgstr "Пресет: название, прогресс и цитата"

msgid "Preset: Name & progress only"
msgstr "Пресет: только название и прогресс"

msgid "Preset: Absolute custom"
msgstr "Пресет: полностью вручную"

msgid "Edit title template…"
msgstr "Изменить шаблон заголовка…"

msgid "Title template"
msgstr "Шаблон заголовка"

msgid "%T %c KOReader codes; empty = use preset title line."
msgstr "Коды KOReader как в сообщении экрана сна; пусто — строка заголовка из пресета."

msgid "Edit stats line template…"
msgstr "Изменить шаблон строки прогресса…"

msgid "Stats line template"
msgstr "Шаблон строки прогресса"

msgid "KOReader codes; empty = keep KOReader sleep message text."
msgstr "Коды KOReader; пусто — оставить текст из настроек сообщения экрана сна."

msgid "Edit quote footer template…"
msgstr "Изменить шаблон подписи к цитате…"

msgid "Quote footer template"
msgstr "Шаблон подписи под цитатой"

msgid "Use %DT %HM %PG %C %A %T — see reference."
msgstr "Используйте %DT %HM %PG %C %A %T — см. справку."

msgid "Placeholder keys reference"
msgstr "Справка по плейсхолдерам"

msgid "Sleep screen placeholder codes"
msgstr "Коды подстановки экрана сна"

msgid "Custom Kobo-style banner"
msgstr "Баннер в стиле Kobo"

msgid "Banner presets for the sleep screen message (Banner layout)."
msgstr "Пресеты баннера для сообщения экрана сна (режим Banner)."

msgid "Title & stats lines use the same codes as the KOReader sleep screen message editor:\n\n"
msgstr "Строки заголовка и прогресса используют те же коды, что редактор сообщения экрана сна в KOReader:\n\n"

msgid "\n\n\nQuote footer (under the highlight) uses doubled percents so it does not clash with KOReader codes:\n\n"
msgstr "\n\n\nПодпись под цитатой использует двойной символ процента, чтобы не пересекаться с кодами KOReader:\n\n"

msgid "Analog clock"
msgstr "Аналоговые часы"

msgid "Analog dial diameter % (50–100)…"
msgstr "Диаметр аналогового циферблата, % (50–100)…"

msgid "Dial diameter"
msgstr "Диаметр циферблата (%)"

msgid "Widget corner radius (px)"
msgstr "Скругление углов виджета (px)"

msgid "Widget corner radius"
msgstr "Скругление углов виджета"

msgid "Widget padding (px)"
msgstr "Внутренний отступ виджета (px)"

msgid "Widget padding"
msgstr "Внутренний отступ виджета"

msgid "Widget vertical gap (px)"
msgstr "Вертикальный зазор между виджетами (px)"

msgid "Widget vertical gap"
msgstr "Вертикальный зазор между виджетами"

msgid "Move widget up"
msgstr "Сдвинуть виджет вверх"

msgid "Move widget down"
msgstr "Сдвинуть виджет вниз"

msgid "Remove widget"
msgstr "Удалить виджет"

msgid "Add widget…"
msgstr "Добавить виджет…"

msgid "READING · TODAY"
msgstr "ЧТЕНИЕ · СЕГОДНЯ"

msgid "MIN"
msgstr "МИН"

msgid "No book open"
msgstr "Нет открытой книги"

msgid "Untitled"
msgstr "Без названия"

msgid "6×3 sleep banner grid with Frame-style widget cards (1–3 column wide widgets): clocks, templates, highlights, date/battery/book/calendar, and reading time."
msgstr "Сетка баннера сна 6×3 с карточками виджетов в стиле Frame (ширина 1–3 колонки): часы, шаблоны, подсветки, дата/батарея/книга/календарь и время чтения."

msgid "When ON, replaces the sleep-screen banner with the 6×3 grid layout when KOReader uses Banner message mode."
msgstr "Если включено, баннер экрана сна заменяется сеткой 6×3 при режиме сообщения «Banner» в KOReader."

msgid "Sleep banner grid (6×3)"
msgstr "Сетка баннера сна (6×3)"

msgid "Grid horizontal inset from screen (px)"
msgstr "Горизонтальный отступ сетки от краёв экрана (px)"

msgid "Left/right margin between the screen border and the 6×3 grid; scaled for DPI. When unset, the combined \"legacy\" inset value is used for this axis."
msgstr "Поля слева и справа между краем экрана и сеткой 6×3; масштабируется под DPI. Если не задано отдельно, для этой оси используется общее (устаревшее) значение отступа."

msgid "Grid horizontal inset (px)"
msgstr "Горизонтальный отступ сетки (px)"

msgid "Grid vertical inset from screen (px)"
msgstr "Вертикальный отступ сетки от краёв экрана (px)"

msgid "Top/bottom margin between the screen border and the 6×3 grid; scaled for DPI. When unset, the combined \"legacy\" inset value is used for this axis."
msgstr "Поля сверху и снизу между краем экрана и сеткой 6×3; масштабируется под DPI. Если не задано отдельно, для этой оси используется общее (устаревшее) значение отступа."

msgid "Grid vertical inset (px)"
msgstr "Вертикальный отступ сетки (px)"

msgid "Default grid / widget gap (px)"
msgstr "Общий зазор сетки и виджетов (px)"

msgid "Default gap"
msgstr "Общий зазор"

msgid "Grid column gap (px, 0 = default gap)"
msgstr "Зазор между столбцами сетки (px, 0 = общий зазор)"

msgid "Column gap"
msgstr "Зазор столбцов"

msgid "Grid row gap (px, 0 = default gap)"
msgstr "Зазор между строками сетки (px, 0 = общий зазор)"

msgid "Row gap"
msgstr "Зазор строк"

msgid "Not enough space for this widget here."
msgstr "Недостаточно места для этого виджета."

msgid "That width does not fit here."
msgstr "Такая ширина здесь не помещается."

msgid "Widget width: 1 column"
msgstr "Ширина виджета: 1 колонка"

msgid "Widget width: 2 columns"
msgstr "Ширина виджета: 2 колонки"

msgid "Widget width: 3 columns"
msgstr "Ширина виджета: 3 колонки"

msgid "Row %d, column %d — empty"
msgstr "Строка %d, столбец %d — пусто"

msgid "Row %d, column %d — %s (%d cols)"
msgstr "Строка %d, столбец %d — %s (%d кол.)"

msgid "Row %d, column %d — %s"
msgstr "Строка %d, столбец %d — %s"

msgid "Row %d, column %d — (wider widget @ %d,%d)"
msgstr "Строка %d, столбец %d — (широкий виджет в %d,%d)"

msgid "This cell is part of a widget anchored at row %d, column %d."
msgstr "Эта ячейка — часть виджета с якорем в строке %d, столбце %d."

msgid "Edit…"
msgstr "Изменить…"

msgid "Row %d (%s)"
msgstr "Строка %d (%s)"
